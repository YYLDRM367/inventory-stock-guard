# ─────────────────────────────────────────────────────────────────────────────
#  .env.example  —  copy to .env.local and fill in.
#
#  The guided setup ("/setup" in Claude Code) does this FOR you: it asks which
#  integrations you want, collects each key, and writes .env.local.
#
#  Every key here is OPTIONAL. With none set, Crate runs in DEMO MODE with a
#  realistic sample catalog, stock and locations so you can see it immediately.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (database & auth) ───────────────────────────────────────────────
# Stores your catalog, stock and movements. https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Barcode Lookup (optional) ────────────────────────────────────────────────
# Auto-fill item name/brand/category from a scanned UPC. https://www.barcodelookup.com/api
BARCODE_LOOKUP_API_KEY=

# ── Shopify sync (optional) ──────────────────────────────────────────────────
# Decrement stock on each storefront sale. https://shopify.dev/docs/api/admin
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_API_TOKEN=

# ── WooCommerce sync (optional) ──────────────────────────────────────────────
# Alternative storefront sync for WordPress/WooCommerce shops.
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
